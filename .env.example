# Email (already in use by app/api/contact and app/api/emailcontact)
EMAIL_USER="your-gmail-address@gmail.com"
EMAIL_PASS="your-gmail-app-password"

# Database — required by app/api/invoices/search/route.ts (@vercel/postgres).
# Get this from your Postgres provider (Neon dashboard, or Vercel Storage tab
# if using Vercel Postgres). Must include ?sslmode=require for hosted DBs.
POSTGRES_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
