# Email (already in use by app/api/contact and app/api/emailcontact)
EMAIL_USER="your-gmail-address@gmail.com"
EMAIL_PASS="your-gmail-app-password"

# Invoice-Generation production database — required by app/api/invoices/search/route.ts.
# This is the AllpackInvoiceGeneration Neon project (the `invoices` table lives there),
# NOT AllPack's own database. Get this connection string from the Invoice-Generation
# repo/Vercel project (Neon dashboard -> AllpackInvoiceGeneration -> Connection Details).
INVOICE_DB_URL="postgresql://USER:PASSWORD@HOST/AllpackInvoiceGeneration?sslmode=require"
